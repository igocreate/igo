{
  "name": "igo",
  "version": "6.0.0-beta.3",
  "homepage": "https://github.com/igocreate/igo",
  "description": "Igo is a Node.js Web Framework based on Express",
  "main": "index.js",
  "scripts": {
    "test": "npm test --workspace=@igojs/server && npm test --workspace=@igojs/db && npm test --workspace=@igojs/dust && npm test --workspace=@igojs/signal",
    "test:dust": "npm test --workspace=@igojs/dust",
    "test:signal": "npm test --workspace=@igojs/signal",
    "test:server": "npm test --workspace=@igojs/server",
    "test:db": "npm test --workspace=@igojs/db",
    "eslint": "eslint ./packages/*/src",
    "compress": "npx @squoosh/cli --resize '{\"enabled\":false}' -d public public/**/*.{jpg,jpeg,png}",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "bin": {
    "igo": "./packages/server/cli/igo.js"
  },
  "keywords": [
    "igocreate",
    "web",
    "expressjs"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:igocreate/igo.git"
  },
  "author": "@igocreate",
  "license": "ISC",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@igojs/db": "^6.0.0-beta.1",
    "@igojs/dust": "^6.0.0-beta.1",
    "@igojs/server": "^6.0.0-beta.2",
    "@igojs/signal": "^6.0.0-beta.1"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "nodemon": "3.1.11",
    "vitepress": "^1.6.4"
  }
}
