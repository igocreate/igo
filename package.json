{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm test --workspace=@igojs/server && npm test --workspace=@igojs/db && npm test --workspace=@igojs/dust && npm test --workspace=@igojs/component",
    "test:dust": "npm test --workspace=@igojs/dust",
    "test:component": "npm test --workspace=@igojs/component",
    "test:server": "npm test --workspace=@igojs/server",
    "test:db": "npm test --workspace=@igojs/db",
    "eslint": "eslint ./packages/*/src",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "vitepress": "^1.6.4"
  },
  "lint-staged": {
    "*.js": "eslint"
  }
}
