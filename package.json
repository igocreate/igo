{
  "name": "igo",
  "version": "6.0.0",
  "homepage": "https://github.com/igocreate/igo",
  "description": "Igo is a Node.js Web Framework based on Express",
  "main": "index.js",
  "scripts": {
    "test": "npm test --workspace=@igo/server && npm test --workspace=@igo/db && npm test --workspace=@igo/dust && npm test --workspace=@igo/signal",
    "test:dust": "npm test --workspace=@igo/dust",
    "test:signal": "npm test --workspace=@igo/signal",
    "test:server": "npm test --workspace=@igo/server",
    "test:db": "npm test --workspace=@igo/db",
    "eslint": "eslint ./packages/*/src",
    "compress": "npx @squoosh/cli --resize '{\"enabled\":false}' -d public public/**/*.{jpg,jpeg,png}"
  },
  "bin": {
    "igo": "./packages/server/cli/igo.js"
  },
  "keywords": [
    "igocreate",
    "web",
    "expressjs"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:igocreate/igo.git"
  },
  "author": "@igocreate",
  "license": "ISC",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@igo/db": "*",
    "@igo/dust": "*",
    "@igo/server": "*",
    "@igo/signal": "*"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "mocha": "^11.7.5",
    "nodemon": "3.1.11"
  }
}
