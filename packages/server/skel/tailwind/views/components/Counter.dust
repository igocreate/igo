<script>
({
  props: {
    // count: 33
  },

  increment() {
    this.props.count++;
  }
})
</script>

<div class="flex items-center gap-4">
  <span class="text-2xl font-bold">{count}</span>
  <button on:click="increment" class="increment-btn cursor-pointer rounded bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700">
    +1
  </button>
</div>
